NODE_ENV=production
HOST=0.0.0.0
PORT=3001
CORS_ORIGIN=

# Bind only to loopback on the host so this container does not affect existing public services.
API_BIND_IP=127.0.0.1
API_PORT=38101

# Future infra wiring
DATABASE_URL=postgresql://studyclaw:change-me@postgres:5432/studyclaw
REDIS_URL=redis://redis:6379
AUTH_TOKEN_TTL_DAYS=30
USER_SECRET_ENCRYPTION_KEY=replace-with-a-long-random-secret
LLM_PROVIDER=openai-compatible
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=
